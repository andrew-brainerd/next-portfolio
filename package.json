{
  "name": "next-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "next build",
    "analyze": "next experimental-analyze",
    "clean": "rm -rf node_modules .next",
    "dev": "next dev --experimental-https --hostname local.brainerd.dev --port 3001",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint:fix": "pnpm lint:js:fix && pnpm lint:css:fix",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "preinstall": "bash scripts/installHooks.sh",
    "start": "next start",
    "update-packages": "npx npm-check-updates@latest -u && pnpm i && git add . && git commit -m \"Update packages\"",
    "test": "vitest run",
    "verify": "tsc --noEmit && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@next/third-parties": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@uidotdev/usehooks": "^2.4.1",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.6",
    "firebase": "^12.13.0",
    "howlongtobeat": "^1.8.0",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "postcss": "^8.5.15",
    "pusher-js": "^8.5.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "lint-staged": "^17.0.5",
    "postcss-html": "^1.8.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "**/*": "npx prettier --write --ignore-unknown"
  }
}
